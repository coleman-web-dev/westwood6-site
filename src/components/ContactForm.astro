---
interface Props {
  formAction?: string;
  submitLabel?: string;
  includePhone?: boolean;
  includeMessage?: boolean;
}

const {
  formAction = '/api/contact',
  submitLabel = 'Send Message',
  includePhone = true,
  includeMessage = true,
} = Astro.props;
---

<form class="contact-form" action={formAction} method="POST">
  <div class="form__group">
    <label for="name" class="form__label">Name <span class="required">*</span></label>
    <input type="text" id="name" name="name" class="form__input" required autocomplete="name" />
  </div>

  <div class="form__group">
    <label for="email" class="form__label">Email <span class="required">*</span></label>
    <input type="email" id="email" name="email" class="form__input" required autocomplete="email" />
  </div>

  {includePhone && (
    <div class="form__group">
      <label for="phone" class="form__label">Phone</label>
      <input type="tel" id="phone" name="phone" class="form__input" autocomplete="tel" />
    </div>
  )}

  {includeMessage && (
    <div class="form__group">
      <label for="message" class="form__label">Message <span class="required">*</span></label>
      <textarea id="message" name="message" class="form__input form__textarea" rows="5" required></textarea>
    </div>
  )}

  <button type="submit" class="form__submit">{submitLabel}</button>
</form>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 36rem;
  }

  .form__label {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.375rem;
  }

  .required {
    color: var(--color-primary);
  }

  .form__input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    transition: border-color 0.2s ease;
  }

  .form__input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(var(--color-primary-rgb), 0.15);
  }

  .form__textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .form__submit {
    align-self: flex-start;
    padding: 0.75rem 2rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-bg);
    background: var(--color-primary);
    border: none;
    border-radius: 0.375rem;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .form__submit:hover {
    opacity: 0.9;
  }
</style>
